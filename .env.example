# Frontend (Vite)
# Set to "1" to run the frontend with an in-browser mock backend (no server needed).
# Leave empty to hit a real backend at VITE_API_TARGET via Vite's dev proxy.
VITE_USE_MOCK=1
VITE_API_TARGET=http://localhost:3001

# Backend (Bun server)
DATABASE_URL=postgres://poker:poker@localhost:5432/planning_poker
PORT=3001
# Where the server finds the built frontend to serve (only used in production).
# STATIC_DIR=./dist

# Docker compose
POSTGRES_USER=poker
POSTGRES_PASSWORD=poker
POSTGRES_DB=planning_poker
APP_PORT=3001
