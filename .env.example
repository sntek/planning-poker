# ── Frontend (Vite dev server only) ───────────────────────────────────
# Backend URL that Vite proxies /api and /ws to during development.
VITE_API_TARGET=http://localhost:3001

# ── Backend (Bun server) ───────────────────────────────────────────────
DATABASE_URL=postgres://poker:poker@localhost:5432/planning_poker
PORT=3001
# Directory to serve built frontend from (set automatically in Docker).
# STATIC_DIR=./dist

# ── Docker compose ─────────────────────────────────────────────────────
POSTGRES_USER=poker
POSTGRES_PASSWORD=poker
POSTGRES_DB=planning_poker
APP_PORT=3001
